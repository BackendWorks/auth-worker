# Application
NODE_ENV=development
APP_NAME=auth-worker
APP_DEBUG=false

# Database (shared with auth-service)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?schema=auth

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=auth-worker:
REDIS_TTL=3600

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_QUEUE=auth_worker_queue

# Mail (SMTP)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=noreply@example.com
